{
  "name": "@blackbelt-technology/pi-dashboard-kb-extension",
  "version": "0.5.4",
  "description": "Isolated pi extension: registers kb_search/kb_neighbors/kb_get tools and a tool_result hook that reindexes markdown on edit and (opt-in) nudges DOX AGENTS.md row upkeep.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/kb-extension"
  },
  "publishConfig": { "access": "public" },
  "keywords": ["pi-package", "pi-extension", "knowledge-base", "dox"],
  "pi": {
    "extensions": ["src/extension.ts"]
  },
  "files": ["src/", "!src/__tests__", "README.md"],
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-sqlite vitest run"
  },
  "dependencies": {
    "@blackbelt-technology/pi-dashboard-kb": "^0.5.4"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "*",
    "@oh-my-pi/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@oh-my-pi/pi-coding-agent": { "optional": true },
    "@oh-my-pi/pi-coding-agent": { "optional": true }
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "*"
  }
}
