{
  "name": "@blackbelt-technology/pi-dashboard-extension",
  "version": "0.5.4",
  "description": "Pi bridge extension for pi-dashboard",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackBeltTechnology/pi-agent-dashboard",
    "directory": "packages/extension"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "src/bridge.ts"
    ],
    "skills": [
      ".pi/skills/pi-dashboard",
      ".pi/skills/browser",
      ".pi/skills/project-init"
    ]
  },
  "files": [
    "src/",
    ".pi/skills/pi-dashboard/",
    ".pi/skills/browser/",
    ".pi/skills/project-init/"
  ],
  "dependencies": {
    "@blackbelt-technology/pi-dashboard-shared": "^0.5.4",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "*",
    "@oh-my-pi/pi-tui": "*",
    "@oh-my-pi/pi-coding-agent": "*",
    "@oh-my-pi/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@oh-my-pi/pi-coding-agent": {
      "optional": true
    },
    "@oh-my-pi/pi-tui": {
      "optional": true
    },
    "@oh-my-pi/pi-coding-agent": {
      "optional": true
    },
    "@oh-my-pi/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@oh-my-pi/pi-tui": "*",
    "@types/ws": "^8.18.1",
    "typebox": "^1.1.33"
  }
}
