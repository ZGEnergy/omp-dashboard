---
import PromptBusVisual from "./feature-visuals/PromptBusVisual.astro";
import DiscoveryVisual from "./feature-visuals/DiscoveryVisual.astro";

export interface Props {
  title: string;
  blurb: string;
  /** Optional image path relative to /public. */
  image?: string;
  imageAlt?: string;
  /** Optional badge (e.g. "Mobile", "Realtime"). */
  badge?: string;
  badgeTone?: "accent" | "success" | "warn";
  /** Tailwind grid span classes, e.g. "md:col-span-6 md:row-span-2". */
  span?: string;
  /** Extra classes. */
  class?: string;
  /** Zero-based index for reveal stagger timing. */
  revealIndex?: number;
  /**
   * Substitute visual for cards without a screenshot. Renders an inline
   * SVG visualization in place of the image area.
   */
  visual?: "promptbus" | "discovery";
}

const {
  title,
  blurb,
  image,
  imageAlt,
  badge,
  badgeTone = "accent",
  span = "md:col-span-4",
  class: cls = "",
  revealIndex = 0,
  visual,
} = Astro.props;

const toneColor =
  badgeTone === "success"
    ? "bg-emerald-400/10 text-emerald-300 border-emerald-400/20"
    : badgeTone === "warn"
      ? "bg-amber-400/10 text-amber-300 border-amber-400/20"
      : "bg-pi-accent/10 text-pi-accent border-pi-accent/30";

// Wide banner cards (md:row-span-2) split horizontally at md+ — text in
// the left half, image/visual in the right half — so the card uses its
// full footprint instead of leaving a vertical void in the middle.
const isWide = span.includes("md:row-span-2");
---

<article
  data-reveal
  style={`--reveal-delay: ${revealIndex}`}
  class:list={[
    "group pi-gradient-border pi-hover-glow relative rounded-2xl bg-pi-surface/60 backdrop-blur-sm overflow-hidden",
    "flex flex-col",
    isWide && "md:flex-row",
    span,
    cls,
  ]}
>
  <div
    class:list={[
      "p-6 flex flex-col gap-3",
      isWide ? "md:w-1/2 md:flex-shrink-0 md:justify-center" : "flex-1",
    ]}
  >
    <div class="flex items-center gap-2">
      <h3 class="text-lg font-semibold tracking-tight text-pi-fg">
        {title}
      </h3>
      {
        badge && (
          <span
            class:list={[
              "inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider",
              toneColor,
            ]}
          >
            <span class="h-1.5 w-1.5 rounded-full bg-current" />
            {badge}
          </span>
        )
      }
    </div>
    <p class="text-sm leading-relaxed text-pi-muted">{blurb}</p>
    <slot name="extra" />
  </div>

  {
    image && (
      <div
        class:list={[
          "relative",
          isWide
            ? "md:flex-1 md:flex md:items-stretch md:overflow-hidden md:border-l md:border-pi-border/40"
            : "mt-auto",
        ]}
      >
        {/* Top divider — only meaningful when image stacks below text. */}
        {!isWide && (
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-pi-accent/30 to-transparent" />
        )}
        {/* Dark variant — visible only when html.dark is set. */}
        <img
          src={image}
          alt={imageAlt ?? title}
          loading="lazy"
          decoding="async"
          class:list={[
            "w-full object-cover object-top group-hover:scale-[1.01] transition-transform duration-500 hidden dark:block",
            isWide ? "h-full md:max-h-none" : "max-h-72",
          ]}
        />
        {/* Light variant — auto-derived from the dark path (desktop/→desktop-light/, mobile/→mobile-light/). */}
        <img
          src={image
            .replace("/screenshots/desktop/", "/screenshots/desktop-light/")
            .replace("/screenshots/mobile/", "/screenshots/mobile-light/")}
          alt={imageAlt ?? title}
          loading="lazy"
          decoding="async"
          class:list={[
            "w-full object-cover object-top group-hover:scale-[1.01] transition-transform duration-500 block dark:hidden",
            isWide ? "h-full md:max-h-none" : "max-h-72",
          ]}
        />
      </div>
    )
  }

  {
    !image && visual === "promptbus" && (
      <div class="mt-auto">
        <PromptBusVisual />
      </div>
    )
  }
  {
    !image && visual === "discovery" && (
      <div class="mt-auto">
        <DiscoveryVisual />
      </div>
    )
  }
</article>
