---
/**
 * Inline SVG visual for the PromptBus feature card.
 * Replaces a missing screenshot — shows TUI ⇄ PromptBus ⇄ Browser
 * routing with a tiny confirm dialog inset.
 */
---

<div class="relative w-full px-6 pb-6 pt-2">
  <svg
    viewBox="0 0 320 140"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto text-pi-accent"
    aria-hidden="true"
  >
    <!-- TUI box -->
    <g>
      <rect x="6" y="46" width="76" height="48" rx="8" class="fill-pi-surface stroke-pi-border" stroke-width="1.2" />
      <text x="44" y="70" text-anchor="middle" class="fill-pi-fg" font-family="ui-monospace, monospace" font-size="10" font-weight="600">TUI</text>
      <text x="44" y="84" text-anchor="middle" class="fill-pi-muted" font-family="ui-sans-serif, system-ui" font-size="8">terminal</text>
    </g>

    <!-- PromptBus hub -->
    <g>
      <rect x="124" y="36" width="72" height="68" rx="10" class="fill-pi-accent/10 stroke-pi-accent" stroke-width="1.2" />
      <text x="160" y="62" text-anchor="middle" class="fill-pi-accent" font-family="ui-sans-serif, system-ui" font-size="10" font-weight="700">PromptBus</text>
      <text x="160" y="76" text-anchor="middle" class="fill-pi-muted" font-family="ui-sans-serif, system-ui" font-size="7">first-answer wins</text>
      <circle cx="160" cy="90" r="2.5" class="fill-pi-accent" />
    </g>

    <!-- Browser box -->
    <g>
      <rect x="238" y="46" width="76" height="48" rx="8" class="fill-pi-surface stroke-pi-border" stroke-width="1.2" />
      <text x="276" y="70" text-anchor="middle" class="fill-pi-fg" font-family="ui-monospace, monospace" font-size="10" font-weight="600">Browser</text>
      <text x="276" y="84" text-anchor="middle" class="fill-pi-muted" font-family="ui-sans-serif, system-ui" font-size="8">phone · TV</text>
    </g>

    <!-- Connecting lines -->
    <line x1="82" y1="70" x2="124" y2="70" class="stroke-pi-accent/60" stroke-width="1.2" stroke-dasharray="3 3" />
    <line x1="196" y1="70" x2="238" y2="70" class="stroke-pi-accent/60" stroke-width="1.2" stroke-dasharray="3 3" />

    <!-- Confirm dialog inset (top) -->
    <g>
      <rect x="118" y="6" width="84" height="22" rx="5" class="fill-pi-bg stroke-pi-border" stroke-width="1" />
      <text x="124" y="20" class="fill-pi-fg" font-family="ui-sans-serif, system-ui" font-size="7" font-weight="600">Confirm?</text>
      <rect x="166" y="11" width="14" height="12" rx="3" class="fill-pi-accent/20 stroke-pi-accent" stroke-width="0.8" />
      <text x="173" y="20" text-anchor="middle" class="fill-pi-accent" font-family="ui-sans-serif, system-ui" font-size="7" font-weight="700">Y</text>
      <rect x="184" y="11" width="14" height="12" rx="3" class="fill-pi-surface stroke-pi-border" stroke-width="0.8" />
      <text x="191" y="20" text-anchor="middle" class="fill-pi-muted" font-family="ui-sans-serif, system-ui" font-size="7">n</text>
    </g>

    <!-- Tag pills (bottom) -->
    <g font-family="ui-sans-serif, system-ui" font-size="7">
      <rect x="106" y="116" width="38" height="14" rx="7" class="fill-pi-accent/10 stroke-pi-accent/40" stroke-width="0.8" />
      <text x="125" y="125" text-anchor="middle" class="fill-pi-accent">confirm</text>
      <rect x="148" y="116" width="32" height="14" rx="7" class="fill-pi-accent/10 stroke-pi-accent/40" stroke-width="0.8" />
      <text x="164" y="125" text-anchor="middle" class="fill-pi-accent">select</text>
      <rect x="184" y="116" width="30" height="14" rx="7" class="fill-pi-accent/10 stroke-pi-accent/40" stroke-width="0.8" />
      <text x="199" y="125" text-anchor="middle" class="fill-pi-accent">input</text>
    </g>
  </svg>
</div>
