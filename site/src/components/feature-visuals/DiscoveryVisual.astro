---
/**
 * Inline SVG visual for the Network discovery feature card.
 * Replaces a missing screenshot — shows mDNS broadcast with a mock
 * list of discovered dashboards on the LAN.
 */
---

<div class="relative w-full px-6 pb-6 pt-2">
  <svg
    viewBox="0 0 320 140"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto text-pi-accent"
    aria-hidden="true"
  >
    <!-- mDNS broadcast rings -->
    <g class="opacity-60">
      <circle cx="40" cy="70" r="10" class="fill-none stroke-pi-accent" stroke-width="1.2" />
      <circle cx="40" cy="70" r="20" class="fill-none stroke-pi-accent/60" stroke-width="1" />
      <circle cx="40" cy="70" r="32" class="fill-none stroke-pi-accent/30" stroke-width="0.8" stroke-dasharray="3 3" />
    </g>
    <text x="40" y="74" text-anchor="middle" class="fill-pi-accent" font-family="ui-sans-serif, system-ui" font-size="9" font-weight="700">mDNS</text>
    <text x="40" y="116" text-anchor="middle" class="fill-pi-muted" font-family="ui-sans-serif, system-ui" font-size="7">_pi-dashboard._tcp</text>

    <!-- Discovered server list -->
    <g font-family="ui-sans-serif, system-ui">
      <rect x="100" y="14" width="216" height="112" rx="8" class="fill-pi-surface stroke-pi-border" stroke-width="1.2" />

      <!-- header -->
      <text x="110" y="28" class="fill-pi-muted" font-size="7" font-weight="600" letter-spacing="1">3 SERVERS FOUND</text>

      <!-- row 1 -->
      <g>
        <circle cx="116" cy="48" r="2.5" class="fill-emerald-400" />
        <text x="124" y="51" class="fill-pi-fg" font-size="8" font-weight="600">studio.local</text>
        <text x="200" y="51" class="fill-pi-muted" font-size="7" font-family="ui-monospace, monospace">192.168.1.42:8000</text>
      </g>

      <!-- row 2 -->
      <g>
        <circle cx="116" cy="74" r="2.5" class="fill-emerald-400" />
        <text x="124" y="77" class="fill-pi-fg" font-size="8" font-weight="600">workshop.local</text>
        <text x="200" y="77" class="fill-pi-muted" font-size="7" font-family="ui-monospace, monospace">192.168.1.55:8000</text>
      </g>

      <!-- row 3 — currently selected -->
      <g>
        <rect x="106" y="88" width="204" height="20" rx="4" class="fill-pi-accent/10 stroke-pi-accent/40" stroke-width="0.8" />
        <circle cx="116" cy="98" r="2.5" class="fill-emerald-400" />
        <text x="124" y="101" class="fill-pi-accent" font-size="8" font-weight="700">tv.local</text>
        <text x="200" y="101" class="fill-pi-accent/80" font-size="7" font-family="ui-monospace, monospace">192.168.1.99:8000</text>
        <text x="296" y="101" text-anchor="end" class="fill-pi-accent" font-size="7" font-weight="700">↵</text>
      </g>

      <!-- footer hint -->
      <text x="110" y="122" class="fill-pi-muted" font-size="6.5">↑↓ navigate · Enter connect</text>
    </g>
  </svg>
</div>
